{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "./modulesJS",
    "rootDir": "./modules",
    "sourceMap": true,

    "noEmitOnError": true,
    "declaration": false,
    "removeComments": true,
  },

  "include": [
    "modules/**/*.ts",
  ],

  "exclude": [
    "node_modules",
    "modulesJS"
  ]
}